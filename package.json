{
  "name": "@interfuse/wordpress-mcp",
  "version": "1.0.3",
  "description": "Git-like WordPress/Elementor sync toolkit (CLI + MCP)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "wordpress-mcp": "dist/npx.js",
    "wordpress-sync": "dist/cli.js",
    "wordpress-sync-mcp": "dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json",
    "cli": "tsx src/cli.ts",
    "mcp": "tsx src/mcp/server.ts",
    "prepack": "npm run build"
  },
  "keywords": [
    "wordpress",
    "elementor",
    "mcp",
    "sync",
    "cli"
  ],
  "author": "InterFuse Agency",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InterFuseAgency/wordpress-sync.git"
  },
  "bugs": {
    "url": "https://github.com/InterFuseAgency/wordpress-sync/issues"
  },
  "homepage": "https://github.com/InterFuseAgency/wordpress-sync#readme",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "prettier": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
